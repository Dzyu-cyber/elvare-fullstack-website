{
  "name": "elvare-fullstack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:api\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "sharp",
      "unrs-resolver",
      "@prisma/engines",
      "prisma"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
